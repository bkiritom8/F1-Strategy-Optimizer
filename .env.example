# F1 Strategy Optimizer — Environment Variables
# Copy to .env before running locally:
#   cp .env.example .env
# Never commit .env to git.

# ── GCP Project ───────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=f1optimizer
PROJECT_ID=f1optimizer
GCP_REGION=us-central1

# ── GCS Paths ─────────────────────────────────────────────────────────────────
GCS_RAW=gs://f1optimizer-data-lake/raw
GCS_PROCESSED=gs://f1optimizer-data-lake/processed
TRAINING_BUCKET=gs://f1optimizer-training
MODELS_BUCKET=gs://f1optimizer-models
DATA_BUCKET=gs://f1optimizer-data-lake

# ── Local Development Mode ────────────────────────────────────────────────────
# Set to true to run scripts without GCS (reads from Data-Pipeline/data/)
USE_LOCAL_DATA=false
# Local cache directory for feature store and GCS downloads
F1_LOCAL_CACHE=/tmp/f1_cache

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── FastF1 Cache ──────────────────────────────────────────────────────────────
FASTF1_CACHE=/tmp/fastf1_cache

# ── API (local) ───────────────────────────────────────────────────────────────
ENV=local
LOG_LEVEL=INFO
ENABLE_HTTPS=false
ENABLE_IAM=true

# ── JWT (REQUIRED in production — store in GCP Secret Manager) ────────────────
# JWT_SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# ── CORS (optional — space-separated extra origins beyond the defaults) ────────
# CORS_EXTRA_ORIGINS=https://your-custom-domain.com

# ── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── LLM / Gemini ─────────────────────────────────────────────────────────────
LLM_PRIMARY_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODEL=gemini-1.5-flash
LLM_CB_FAILURE_THRESHOLD=5
LLM_CB_RECOVERY_TIMEOUT_S=30
LLM_RATE_LIMIT_RPM=10
LLM_BATCH_MAX_SIZE=50
LLM_BATCH_MAX_WAIT_MS=100
LLM_BATCH_MAX_CONCURRENT=20

# ── Simulation ────────────────────────────────────────────────────────────────
# External Monte Carlo simulation endpoint (rule-based fallback activates if unset)
SIMULATION_ENDPOINT=
# RL strategy model directory (relative or GCS path)
RL_MODEL_DIR=models/rl_strategy/v3

# ── Seed / Admin ─────────────────────────────────────────────────────────────
# Secret used by POST /admin/seed — keep empty locally, set in Secret Manager for prod
SEED_SECRET=

# ── Email (account verification) ─────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # Gmail app password — myaccount.google.com/apppasswords
EMAIL_FROM=your@gmail.com
APP_BASE_URL=http://localhost:3001   # frontend URL — used to build verify link
# SendGrid (alternative to SMTP — set EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=

# ── Frontend (Vite build — set in .env.local for local dev, GitHub secrets for CI) ──
# VITE_API_URL=https://f1-strategy-api-dev-...run.app
# VITE_CLOUD_RUN_URL=https://f1-strategy-api-dev-...run.app
# VITE_API_USER=<service-account-username>
# VITE_API_PASS=<service-account-password>
